---
import Base from '../layouts/Base.astro';
---

<Base title="simpleBudget — Budgeting Made Simple">
  <section class="hero">
    <h1>Budgeting that gets<br />out of your way</h1>
    <p class="hero-sub">
      Plan your month, track your spending, and see where your money goes — all in one clean interface. No spreadsheets, no complexity.
    </p>
    <div class="hero-cta">
      <a href="https://app.simplebudget.com/signup" class="btn btn-primary btn-large">Start for Free</a>
      <a href="/pricing" class="btn btn-secondary btn-large">See Pricing</a>
    </div>
  </section>

  <section class="features">
    <div class="feature-card">
      <div class="feature-icon">📋</div>
      <h3>Plan Your Budget</h3>
      <p>Set up income and expense categories in seconds. Use our starter template or build your own from scratch.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon">💸</div>
      <h3>Track Transactions</h3>
      <p>Log expenses and income as they happen. See exactly how much you have left in each category.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon">👥</div>
      <h3>Share with a Partner</h3>
      <p>Share budgets with your spouse or roommate. Everyone stays on the same page.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon">📊</div>
      <h3>See the Big Picture</h3>
      <p>Visual analytics show your spending patterns over time. Know where your money actually goes.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon">📱</div>
      <h3>Works Everywhere</h3>
      <p>Install as a PWA on your phone or use it in any browser. Your budget is always with you.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon">🔒</div>
      <h3>Private & Secure</h3>
      <p>Your financial data is never sold or shared. We make money from subscriptions, not your data.</p>
    </div>
  </section>

  <section class="how-it-works">
    <h2>Up and running in 2 minutes</h2>
    <div class="steps">
      <div class="step">
        <span class="step-number">1</span>
        <h3>Create your budget</h3>
        <p>Name it, pick a template (or start blank), and you're ready to go.</p>
      </div>
      <div class="step">
        <span class="step-number">2</span>
        <h3>Set your amounts</h3>
        <p>Assign dollar amounts to each category. See your planned income vs. expenses at a glance.</p>
      </div>
      <div class="step">
        <span class="step-number">3</span>
        <h3>Track as you spend</h3>
        <p>Add transactions throughout the month. Watch your remaining balances update in real time.</p>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <h2>Ready to take control?</h2>
    <p>Join thousands of people who budget the simple way.</p>
    <a href="https://app.simplebudget.com/signup" class="btn btn-primary btn-large">Get Started — It's Free</a>
  </section>
</Base>

<style>
  .hero {
    text-align: center;
    padding: 6rem 0 4rem;
  }

  .hero h1 {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  .hero-sub {
    margin-top: 1.25rem;
    font-size: 1.2rem;
    color: var(--color-text-muted);
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-cta {
    margin-top: 2.5rem;
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    padding: 4rem 0;
  }

  .feature-card {
    background: var(--color-surface);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius);
    padding: 1.75rem;
    transition: border-color 0.2s;
  }

  .feature-card:hover {
    border-color: rgba(255, 255, 255, 0.12);
  }

  .feature-icon {
    font-size: 1.75rem;
    margin-bottom: 0.75rem;
  }

  .feature-card h3 {
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
  }

  .feature-card p {
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .how-it-works {
    padding: 4rem 0;
    text-align: center;
  }

  .how-it-works h2 {
    font-size: 2rem;
    margin-bottom: 2.5rem;
  }

  .steps {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 2rem;
    text-align: left;
  }

  .step {
    position: relative;
    padding-left: 3.5rem;
  }

  .step-number {
    position: absolute;
    left: 0;
    top: 0;
    width: 2.5rem;
    height: 2.5rem;
    background: var(--color-primary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1rem;
  }

  .step h3 {
    font-size: 1.05rem;
    margin-bottom: 0.4rem;
  }

  .step p {
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .cta-section {
    text-align: center;
    padding: 5rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    margin-top: 2rem;
  }

  .cta-section h2 {
    font-size: 2rem;
    margin-bottom: 0.75rem;
  }

  .cta-section p {
    color: var(--color-text-muted);
    font-size: 1.1rem;
    margin-bottom: 2rem;
  }
</style>
