---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allGuides = await getCollection('guides');

const categories = [
  { key: 'getting-started', label: 'Getting Started' },
  { key: 'install', label: 'Install the App' },
  { key: 'features', label: 'Features & How-Tos' },
] as const;

const grouped = categories.map(cat => ({
  ...cat,
  guides: allGuides
    .filter(g => g.data.category === cat.key)
    .sort((a, b) => a.data.order - b.data.order),
}));
---

<Base title="Guides — simpleBudget" description="Learn how to get the most out of simpleBudget with step-by-step guides.">
  <section class="guides-hero">
    <h1>Guides</h1>
    <p>Step-by-step help for everything in simpleBudget.</p>
  </section>

  <section class="guides-list">
    {grouped.map(group => (
      <div class="guide-group">
        <h2>{group.label}</h2>
        <div class="guide-cards">
          {group.guides.map(guide => (
            <a href={`/guides/${guide.id}`} class="guide-card">
              <h3>{guide.data.title}</h3>
              <p>{guide.data.description}</p>
            </a>
          ))}
        </div>
      </div>
    ))}
  </section>
</Base>

<style>
  .guides-hero {
    padding: 5rem 0 3rem;
  }

  .guides-hero h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
  }

  .guides-hero p {
    margin-top: 0.75rem;
    color: var(--color-text-muted);
    font-size: 1.15rem;
  }

  .guides-list {
    padding-bottom: 4rem;
  }

  .guide-group {
    margin-bottom: 2.5rem;
  }

  .guide-group h2 {
    font-size: 1.25rem;
    margin-bottom: 1rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-weight: 600;
  }

  .guide-cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1rem;
  }

  .guide-card {
    background: var(--color-surface);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius);
    padding: 1.5rem;
    transition: border-color 0.2s, transform 0.1s;
    display: block;
  }

  .guide-card:hover {
    border-color: var(--color-primary);
    transform: translateY(-2px);
  }

  .guide-card h3 {
    font-size: 1.05rem;
    margin-bottom: 0.4rem;
    color: var(--color-text);
  }

  .guide-card p {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.5;
  }
</style>
