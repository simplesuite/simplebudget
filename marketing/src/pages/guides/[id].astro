---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map(guide => ({
    params: { id: guide.id },
    props: { guide },
  }));
}

const { guide } = Astro.props;
const { Content } = await render(guide);
---

<Base title={`${guide.data.title} — simpleBudget`} description={guide.data.description}>
  <article class="guide">
    <a href="/guides" class="back-link">← All Guides</a>
    <h1>{guide.data.title}</h1>
    <div class="guide-content">
      <Content />
    </div>
  </article>
</Base>

<style>
  .guide {
    max-width: 700px;
    padding: 3rem 0 5rem;
  }

  .back-link {
    display: inline-block;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--color-primary);
  }

  .guide h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 2rem;
  }

  .guide-content {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .guide-content :global(h2) {
    color: var(--color-text);
    font-size: 1.35rem;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }

  .guide-content :global(h3) {
    color: var(--color-text);
    font-size: 1.1rem;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }

  .guide-content :global(p) {
    margin-bottom: 1rem;
  }

  .guide-content :global(ol),
  .guide-content :global(ul) {
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }

  .guide-content :global(li) {
    margin-bottom: 0.5rem;
  }

  .guide-content :global(strong) {
    color: var(--color-text);
  }

  .guide-content :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .guide-content :global(a:hover) {
    color: #5a93b3;
  }

  .guide-content :global(code) {
    background: rgba(255, 255, 255, 0.06);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.9em;
  }
</style>
